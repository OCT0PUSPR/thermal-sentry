# thermal-sentry configuration (copy to .env). All vars are prefixed TS_.
# Nested settings use a double underscore: TS_ALERTS__... -> alerts group.
# NEVER commit a real .env with secrets -- this file holds placeholders only.

# ---- source -----------------------------------------------------------------
# simulate | mlx90640 | file
TS_SOURCE=simulate
TS_FPS=8

# ---- MLX90640 hardware (only used when TS_SOURCE=mlx90640) -------------------
# Refresh rate Hz: 0.5 | 1 | 2 | 4 | 8 | 16 | 32 | 64
TS_MLX_REFRESH_RATE=8
TS_MLX_I2C_FREQUENCY=800000

# ---- simulator (TS_SOURCE=simulate) -----------------------------------------
TS_SIM_SEED=42
TS_SIM_NUM_BODIES=2
TS_SIM_AMBIENT_C=22.0
TS_SIM_BODY_TEMP_C=34.0
TS_SIM_NOISE_STD=0.4

# ---- file replay (TS_SOURCE=file) -------------------------------------------
# TS_FILE_PATH=captures/clip.npy
TS_FILE_LOOP=true

# ---- preprocessing / display ------------------------------------------------
TS_UPSCALE=20
TS_COLORMAP=ironbow              # ironbow | inferno | grayscale
TS_TEMP_DISPLAY_MIN_C=18.0
TS_TEMP_DISPLAY_MAX_C=40.0

# ---- web dashboard ----------------------------------------------------------
TS_WEB_HOST=0.0.0.0
TS_WEB_PORT=8000

# ---- detection (TS_DET_*) ---------------------------------------------------
# NB: areas are measured on the UPSCALED frame, so they scale with TS_UPSCALE^2.
# These defaults are tuned for TS_UPSCALE=20 (a person ~= 3.5k-11k px).
TS_DET_HOT_THRESHOLD_C=29.0
TS_DET_ADAPTIVE=true
TS_DET_ADAPTIVE_K=3.0
TS_DET_MIN_AREA=400
TS_DET_PERSON_MIN_AREA=800
TS_DET_PERSON_MAX_AREA=20000
TS_DET_PERSON_MIN_TEMP_C=30.0
TS_DET_PERSON_MAX_TEMP_C=40.0
TS_DET_HOTSPOT_TEMP_C=45.0

# ---- tracker (TS_TRACK_*) ---------------------------------------------------
TS_TRACK_MAX_DISTANCE=40.0
TS_TRACK_MAX_MISSED=8
TS_TRACK_MIN_IOU=0.0

# ---- anomaly rules (TS_ANOM_*) ----------------------------------------------
TS_ANOM_OVERHEAT_TEMP_C=50.0
TS_ANOM_RAPID_RISE_DELTA_C=8.0
TS_ANOM_RAPID_RISE_WINDOW_S=5.0
TS_ANOM_LOITER_SECONDS=20.0
TS_ANOM_MAX_PERSON_COUNT=5
# Restricted zones are normalised polygons; set via the dashboard or JSON env:
# TS_ANOM_RESTRICTED_ZONES=[[[0.1,0.1],[0.4,0.1],[0.4,0.5],[0.1,0.5]]]

# ---- alerts (TS_ALERTS_*) ---------------------------------------------------
TS_ALERTS_CONSOLE=true
TS_ALERTS_JSONL_PATH=captures/alerts.jsonl
TS_ALERTS_DEBOUNCE_SECONDS=15

# Webhook (e.g. a Slack / Discord / generic incoming webhook URL). Secret -> env.
# TS_ALERTS_WEBHOOK_URL=https://hooks.example.com/services/REPLACE_ME

# Email (SMTP). Credentials come from the environment -- never hardcode them.
TS_ALERTS_EMAIL_ENABLED=false
# TS_ALERTS_EMAIL_TO=ops@example.com
# TS_ALERTS_EMAIL_FROM=thermal-sentry@example.com
# TS_ALERTS_SMTP_HOST=smtp.example.com
# TS_ALERTS_SMTP_PORT=587
# TS_ALERTS_SMTP_USER=REPLACE_ME
# TS_ALERTS_SMTP_PASSWORD=REPLACE_ME
