# thermal-sentry configuration (copy to .env). All vars are prefixed TS_.
# Nested settings use a double underscore: TS_ALERTS__... -> alerts group.
# NEVER commit a real .env with secrets -- this file holds placeholders only.

# ---- source -----------------------------------------------------------------
# simulate | mlx90640 | file
TS_SOURCE=simulate
TS_FPS=8

# ---- MLX90640 hardware (only used when TS_SOURCE=mlx90640) -------------------
# Refresh rate Hz: 0.5 | 1 | 2 | 4 | 8 | 16 | 32 | 64
TS_MLX_REFRESH_RATE=8
TS_MLX_I2C_FREQUENCY=800000

# ---- simulator (TS_SOURCE=simulate) -----------------------------------------
TS_SIM_SEED=42
TS_SIM_NUM_BODIES=2
TS_SIM_AMBIENT_C=22.0
TS_SIM_BODY_TEMP_C=34.0
TS_SIM_NOISE_STD=0.4

# ---- file replay (TS_SOURCE=file) -------------------------------------------
# TS_FILE_PATH=captures/clip.npy
TS_FILE_LOOP=true

# ---- preprocessing / display ------------------------------------------------
TS_UPSCALE=20
TS_COLORMAP=ironbow              # ironbow | inferno | grayscale
TS_TEMP_DISPLAY_MIN_C=18.0
TS_TEMP_DISPLAY_MAX_C=40.0

# ---- web dashboard ----------------------------------------------------------
TS_WEB_HOST=0.0.0.0
TS_WEB_PORT=8000

# ---- detection (TS_DET_*) ---------------------------------------------------
# NB: areas are measured on the UPSCALED frame, so they scale with TS_UPSCALE^2.
# These defaults are tuned for TS_UPSCALE=20 (a person ~= 3.5k-11k px).
TS_DET_HOT_THRESHOLD_C=29.0
TS_DET_ADAPTIVE=true
TS_DET_ADAPTIVE_K=3.0
TS_DET_MIN_AREA=400
TS_DET_PERSON_MIN_AREA=800
TS_DET_PERSON_MAX_AREA=20000
TS_DET_PERSON_MIN_TEMP_C=30.0
TS_DET_PERSON_MAX_TEMP_C=40.0
TS_DET_HOTSPOT_TEMP_C=45.0

# ---- tracker (TS_TRACK_*) ---------------------------------------------------
TS_TRACK_MAX_DISTANCE=40.0
TS_TRACK_MAX_MISSED=8
TS_TRACK_MIN_IOU=0.0

# ---- anomaly rules (TS_ANOM_*) ----------------------------------------------
TS_ANOM_OVERHEAT_TEMP_C=50.0
TS_ANOM_RAPID_RISE_DELTA_C=8.0
TS_ANOM_RAPID_RISE_WINDOW_S=5.0
TS_ANOM_LOITER_SECONDS=20.0
TS_ANOM_MAX_PERSON_COUNT=5
# Restricted zones are normalised polygons; set via the dashboard or JSON env:
# TS_ANOM_RESTRICTED_ZONES=[[[0.1,0.1],[0.4,0.1],[0.4,0.5],[0.1,0.5]]]

# ---- alerts (TS_ALERTS_*) ---------------------------------------------------
TS_ALERTS_CONSOLE=true
TS_ALERTS_JSONL_PATH=captures/alerts.jsonl
TS_ALERTS_DEBOUNCE_SECONDS=15

# Webhook (e.g. a Slack / Discord / generic incoming webhook URL). Secret -> env.
# TS_ALERTS_WEBHOOK_URL=https://hooks.example.com/services/REPLACE_ME

# Email (SMTP). Credentials come from the environment -- never hardcode them.
TS_ALERTS_EMAIL_ENABLED=false
# TS_ALERTS_EMAIL_TO=ops@example.com
# TS_ALERTS_EMAIL_FROM=thermal-sentry@example.com
# TS_ALERTS_SMTP_HOST=smtp.example.com
# TS_ALERTS_SMTP_PORT=587
# TS_ALERTS_SMTP_USER=REPLACE_ME
# TS_ALERTS_SMTP_PASSWORD=REPLACE_ME

# MQTT (IoT / Home Assistant). Credentials from env.
TS_ALERTS_MQTT_ENABLED=false
# TS_ALERTS_MQTT_HOST=mqtt.example.com
# TS_ALERTS_MQTT_PORT=1883
# TS_ALERTS_MQTT_TOPIC=thermal-sentry/alerts
# TS_ALERTS_MQTT_USERNAME=REPLACE_ME
# TS_ALERTS_MQTT_PASSWORD=REPLACE_ME

# Telegram. Bot token + chat id from env.
TS_ALERTS_TELEGRAM_ENABLED=false
# TS_ALERTS_TELEGRAM_BOT_TOKEN=REPLACE_ME
# TS_ALERTS_TELEGRAM_CHAT_ID=REPLACE_ME

# ---- learned model / ML detector (TS_ML_*) ----------------------------------
# Backend: classical | onnx | tflite | ml
#   classical -> heuristic detector only (no model).
#   onnx/tflite -> learned classifier REFINES a classical blob's label.
#   ml -> full-frame two-head CNN LOCALISES + classifies (heatmap detector).
# Any ML backend falls back to the classical detector if the model is missing.
TS_ML_BACKEND=classical
TS_ML_ONNX_MODEL_PATH=models/thermal_cnn.onnx
TS_ML_INT8_ONNX_MODEL_PATH=models/thermal_cnn_int8.onnx
TS_ML_TFLITE_MODEL_PATH=models/thermal_cnn_int8.tflite
TS_ML_MIN_CONFIDENCE=0.30
TS_ML_HEATMAP_PEAK_THRESHOLD=0.30

# ---- web security / auth (TS_SEC_*) -----------------------------------------
# Auth is ON by default. Secrets come from env; if unset a random value is
# generated at startup and logged once (dev only -- SET THESE in production).
TS_SEC_AUTH_ENABLED=true
# TS_SEC_API_KEY=REPLACE_ME_LONG_RANDOM
# TS_SEC_BASIC_AUTH_USER=admin
# TS_SEC_BASIC_AUTH_PASSWORD=REPLACE_ME
# TS_SEC_SESSION_SECRET=REPLACE_ME_LONG_RANDOM
TS_SEC_RATE_LIMIT=120/minute
TS_SEC_RATE_LIMIT_ENABLED=true
TS_SEC_SECURITY_HEADERS=true
# CORS allowlist is empty by default ("*" is never a default). Add exact origins:
# TS_SEC_CORS_ORIGINS=["https://dash.example.com"]

# ---- event store / persistence (TS_DB_*) ------------------------------------
TS_DB_ENABLED=true
TS_DB_URL=sqlite:///captures/thermal_sentry.db
TS_DB_RETENTION_DAYS=30
TS_DB_RECORD_CLIPS=false
# TS_DB_CLIPS_DIR=recordings

# ---- observability (TS_OBS_*) -----------------------------------------------
TS_OBS_LOG_FORMAT=json          # json (prod) | console (pretty dev)
TS_OBS_LOG_LEVEL=INFO
TS_OBS_METRICS_ENABLED=true

# ---- async runtime / watchdog (TS_RT_*) -------------------------------------
TS_RT_QUEUE_MAXSIZE=4
TS_RT_WATCHDOG_TIMEOUT_S=10.0
TS_RT_SENSOR_MAX_RETRIES=3
